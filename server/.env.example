# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/gamelog-reporter

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# 日志配置
LOG_LEVEL=info

# CORS配置（多个源用逗号分隔）
CORS_ORIGIN=http://localhost:3001,http://localhost:4200,http://127.0.0.1:3001

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
 