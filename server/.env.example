# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/gamelog-reporter

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# 日志配置
LOG_LEVEL=info

# CORS配置（多个源用逗号分隔）
# 局域网网段(localhost/127.x/10.x/172.16-31.x/192.168.x)始终自动放行，无需配置。
# 仅当需要放行公网固定域名时，在此追加（逗号分隔）。
CORS_ORIGIN=

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
 