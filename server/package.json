{
  "name": "gamelog-reporter-server",
  "version": "1.0.0",
  "description": "游戏日志上报平台 - API服务器",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "seed": "ts-node-dev --transpile-only src/scripts/seed-admin.ts",
    "seed:logs": "ts-node-dev --transpile-only src/scripts/seed-logs.ts",
    "clean:test-logs": "ts-node-dev --transpile-only src/scripts/clean-test-logs.ts",
    "close:stale-sessions": "ts-node-dev --transpile-only src/scripts/close-stale-sessions.ts"
  },
  "keywords": [
    "game",
    "log",
    "reporter",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "joi": "^17.10.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "winston": "^3.10.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.6.1",
    "compression": "^1.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.2",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.4",
    "@types/compression": "^1.7.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "eslint": "^8.47.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
